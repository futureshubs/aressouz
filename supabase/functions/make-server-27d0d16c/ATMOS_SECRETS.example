# Atmos Merchant API — Supabase Edge Function Secrets
# PARTNER.ARESSO / docs.atmos.uz — repoga haqiqiy qiymat yozmang.

ATMOS_STORE_ID=
ATMOS_CONSUMER_KEY=
ATMOS_CONSUMER_SECRET=

# Bo‘sh qoldirilsa: prod default https://api.atmos.uz (Edge bilan ishonchliroq).
# Rasmiy apigw kerak bo‘lsa: ATMOS_API_URL=https://apigw.atmos.uz
# Ixtiyoriy terminal (faqat ba’zi do‘konlar): ATMOS_TERMINAL_ID=

# true = yuqoridagi default sandbox host (agar ATMOS_API_URL bo‘sh bo‘lsa)
ATMOS_USE_SANDBOX=false

# Token / boshqa so‘rovlar uchun vaqt (ms). Edge → Atmos sekin bo‘lsa oshiring.
# ATMOS_OAUTH_TIMEOUT_MS=60000
# ATMOS_FETCH_TIMEOUT_MS=45000

# Yoki admin → To‘lovlar → Atmos: storeId, consumerKey, consumerSecret, apiBaseUrl (KV ustunlik)
