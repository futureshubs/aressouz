# Payme / Paycom Subscribe API — Supabase Edge Function Secrets
# Qiymatlarni faqat Dashboard → Secrets ga qo‘ying; repoga commit qilmang.

# Agar avval admin «to‘lov usuli» ni saqlagan bo‘lsangiz: eski kod default isTestMode=true qilgan —
# KV da test yoqilgan bo‘lishi mumkin. Admin panelda Payme uchun test rejimini o‘chiring yoki
# payment_method:payme ni qayta saqlang (yangi default: faqat aniq test=true bo‘lsa test).
#
# «Поставщик не найден или заблокирован» — odatda noto‘g‘ri ID yoki test/prod aralashgan:
#   • PAYCOM_REGISTER_ID = Payme Business kabinetdagi **ID кассы** (Subscribe API), eski merchant.payme.uz dagi boshqa ID bilan aralashtirmang.
#   • Test kassa + PAYCOM_SECRET_TEST + PAYCOM_USE_TEST=true (yoki admin: Payme test rejimi).
#   • Prod kassa + PAYCOM_SECRET_PROD + PAYCOM_USE_TEST=false.

# Yangi nomlar (tavsiya):
PAYCOM_REGISTER_ID=

# Yoki eski nomlar — kod ikkalasini ham o‘qiydi:
# PAYME_MERCHANT_ID   → ID кассы (Subscribe API register)
# PAYME_SECRET_KEY    → X-Auth uchun kalit

PAYCOM_SECRET_PROD=
PAYCOM_SECRET_TEST=

# true = test kalit + checkout.test.paycom.uz
# false yoki bo‘sh = prod kalit + checkout.paycom.uz
PAYCOM_USE_TEST=false

# Ixtiyoriy: to‘liq API URL (masalan https://checkout.test.paycom.uz/api)
# MUHIM: URL test bo‘lsa (hostname da test.paycom) — faqat test rejimida; prod URL — faqat prod.
# Noto‘g‘ri juftlik (test kalit + prod URL) yoki aksincha chek yaratiladi, checkout «чек не найден» beradi.
# PAYCOM_API_URL=

# Checkout havolasiga `back=` (faqat https). Localhost bo‘lsa payme.uz «чек не найден» / back=null berishi mumkin.
# Lokal `npm run dev`: loyiha ildizidagi `.env` da VITE_PAYME_RETURN_URL=https://sizning-sayt.uz/ (create-receipt body orqali yuboriladi).
# PAYME_CHECKOUT_BACK_URL=https://your-domain.uz/
# PAYCOM_CHECKOUT_BACK_URL=  (alias)
# PUBLIC_APP_URL / SITE_URL / SUPABASE_URL — avtomatik sinab ko‘rinadi (https bo‘lsa)
# Hech narsa bo‘lmasa kod vaqtincha https://payme.uz/ qo‘yadi (o‘z saytingizni Callback URL ga yozing).

# Prod checkout: default checkout.paycom.uz/{id} (tavsiya). To‘g‘ridan payme.uz: PAYCOM_CHECKOUT_STYLE=payme

# Mahsulot ИКПУ (nol bo‘lsa checkout xato berishi mumkin) — bitta default
# PAYCOM_DEFAULT_ITEM_CODE=00702001001000001
# PAYCOM_DEFAULT_UNITS=241092

# Edge function loglarida har bir Paycom RPC vaqti / muvaffaqiyat (maxfiy kalit chiqmaydi)
# PAYCOM_DEBUG_LOG=true
# To‘liq RPC params (items qatorlari qisqartirilgan) — PAYME_HTTP_DEBUG=true
