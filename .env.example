# Edge function (make-server-27d0d16c): vergul bilan ruxsat etilgan Originlar. Bo‘sh bo‘lsa CORS `*`.
# Production: ro‘yxatni to‘ldiring va quyidagi majburiy rejimni yoqing.
# ALLOWED_ORIGINS=https://sizning-domen.uz,https://www.sizning-domen.uz,https://aresso.app
# ALLOWED_ORIGINS_REQUIRED=1
# Yoki hosted Supabase (*.supabase.co) uchun bitta kalit — ALLOWED_ORIGINS majbur (wildcard yo‘q):
# EDGE_PRODUCTION_CORS=1
# (Ixtiyoriy) Auth marshrutlariga per-instance rate limit: EDGE_RATE_LIMIT_AUTH=1, EDGE_RATE_LIMIT_AUTH_MAX=120
# (Ixtiyoriy) Barcha marshrutlar (health / click / payme / atmos istisno): EDGE_GLOBAL_RATE_LIMIT=1, EDGE_GLOBAL_RATE_LIMIT_MAX=2000
# (Ixtiyoriy) Login/SMS/admin: EDGE_SENSITIVE_RATE_LIMIT=1, EDGE_SENSITIVE_RATE_LIMIT_MAX=90
# (Ixtiyoriy) 429 hodisalarini stderr JSON (console noop bo‘lsa ham): EDGE_SECURITY_LOG=1
# Batafsil `/test-deployment` javobi (API ro‘yxati) — odatda o‘chiq; faqat debug uchun.
# ENABLE_PUBLIC_TEST_ENDPOINT=1
# So‘rov / auth batafsil loglari (maxfiy sarlavhalar redaktsiya qilinadi). Odatda o‘chiq.
# DEBUG_HTTP=1
# Edge function konsolini yoqish (ikkalasi ham o‘chiq bo‘lsa console.* chiqmaydi).
# VERBOSE_SERVER_LOG=1

# Ixtiyoriy: sayt aloqa va ijtimoiy havolalar (Vite: faqat VITE_ prefiksli kalitlar clientga chiqadi)
# VITE_SUPPORT_EMAIL=support@sizning-domen.uz
# VITE_SOCIAL_INSTAGRAM=https://www.instagram.com/sizning_akkaunt
# VITE_SOCIAL_TELEGRAM=https://t.me/sizning_kanal
# VITE_SOCIAL_FACEBOOK=https://www.facebook.com/sizning-sahifa

# SEO: canonical va sitemap uchun prod URL (build script yoki qo‘lda public/sitemap.xml ni yangilang).
# VITE_PUBLIC_SITE_URL=https://sizning-domen.uz

# (Ixtiyoriy) Sentry brauzer xatolari — bo‘sh bo‘lsa Sentry yuklanmaydi.
# VITE_SENTRY_DSN=https://...@....ingest.sentry.io/...
# (Kelajak) Realtime tayyorligi — hozircha polling o‘zgarmaydi.
# VITE_SUPABASE_REALTIME=1

# Click alohida Edge (`payment-webhooks`): `npm run supabase:deploy` allaqachon deploy qiladi.
# Kabinet URL: https://<PROJECT>.supabase.co/functions/v1/payment-webhooks/click/prepare (COMPLETE — /click/complete)
# Atmos mobil/klient URL (ixtiyoriy alohida funksiya): .../payment-webhooks/atmos/create-transaction
# Payme chek API (ixtiyoriy): .../payment-webhooks/payme/create-receipt|check-receipt|...
# Asosiy serverda Click ni o‘chirish (kabinet faqat payment-webhooks ga ulangan bo‘lsa): EDGE_DISABLE_CLICK_ON_MAIN=1
#
# Click to‘lov URL (Edge Secrets — Vite .env emas): my.click.uz vs test.click.uz
#   Supabase → Edge Functions → Secrets: CLICK_SERVICE_ID, CLICK_MERCHANT_ID, CLICK_MERCHANT_USER_ID, CLICK_SECRET_KEY
#   Test muhit: CLICK_USE_TEST=true yoki CLICK_TEST_MODE=true (bo‘sh/yolg‘on = prod my.click)
#   Qat’iy prod: CLICK_FORCE_PRODUCTION=true (KV/admin «test» bayrog‘ini ham e’tiborsiz qiladi)
#   To‘liq URL (ixtiyoriy): CLICK_PAY_BASE_URL=https://my.click.uz/services/pay
